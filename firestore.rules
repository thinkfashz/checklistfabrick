rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Fields: id, name, progress, activePhase, lastUpdated, deliveryCountdown, constructionPhaseProgress
    //
    // Collection: users
    // Fields: id, name, email, role, photoUrl
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "faubricioedms@gmail.com" && request.auth.token.email_verified == true));
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /phases/{phaseId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      match /deadlines/{deadlineId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      match /files/{fileId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }

      match /posts/{postId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }
  }
}
